# Jeepay Manager - Railway 环境变量配置模板
# 使用方法：将此文件中的值替换为你的实际配置

# ==================== 数据库配置（必需）===================

# MySQL连接地址
# Railway内部使用：mysql.railway.internal
# 外部MySQL：your-mysql-host:3306
SPRING_DATASOURCE_URL=jdbc:mysql://mysql.railway.internal:3306/jeepaydb?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true

# MySQL用户名
SPRING_DATASOURCE_USERNAME=root

# MySQL密码
SPRING_DATASOURCE_PASSWORD=your_mysql_password_here

# ==================== Redis配置（必需）===================

# Redis主机地址
# Railway内部使用：redis.railway.internal
# 外部Redis：your-redis-host
SPRING_DATA_REDIS_HOST=redis.railway.internal

# Redis端口
SPRING_DATA_REDIS_PORT=6379

# Redis密码（如果有）
SPRING_DATA_REDIS_PASSWORD=

# ==================== RocketMQ配置（必需）===================

# RocketMQ NameServer地址
# Railway不提供RocketMQ，请使用阿里云MQ或自建RocketMQ
# 阿里云MQ示例：rmq-cn-xxxx.rocketmq.aliyun.com:8080
ROCKETMQ_NAMESRV_ADDR=your-rocketmq-host:9876

# ==================== 应用配置（必需）===================

# 应用端口
SERVER_PORT=9217

# 应用名称
SPRING_APPLICATION_NAME=jeepay-manager

# ==================== 日志配置（可选）===================

# 日志级别：DEBUG, INFO, WARN, ERROR
LOGGING_LEVEL_ROOT=INFO

# Jeepay详细日志
LOGGING_LEVEL_COM_JEEQUAN=INFO

# ==================== JVM配置（可选）===================

# Java虚拟机参数
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError

# ==================== 其他配置（可选）===================

# 文件上传大小限制
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=10MB

# Session超时时间（秒）
SERVER_SERVLET_SESSION_TIMEOUT=3600

# API超时时间（毫秒）
JEepay_API_TIMEOUT=30000
